# Dashboard login secret. Set the REAL value as an export in ~/.bashrc, not here.
# Must be >=16 chars; the server refuses to boot if it still starts with "change-me".
# Generate one: openssl rand -hex 24
DECK_TOKEN=change-me-openssl-rand-hex-24
# Model auth for the spawned CLI. API key is the contract; a local Claude Code
# subscription login (~/.claude/.credentials.json) works as a fallback.
ANTHROPIC_API_KEY=
# Root that sessions are jailed under (projects are its immediate subdirs).
# Defaults to the process cwd if unset.
PROJECTS_ROOT=/home/anivaryam/github/repositories/projects
PORT=8787
DECK_MODEL=claude-opus-4-8
# Full tunnel origin for the WebSocket + CSRF Origin allowlist (phone access via the
# tunnel). proc-compose.yml already sets this for `proc-compose up`; only needed
# here if you run the server standalone behind the tunnel.
DECK_PUBLIC_ORIGIN=https://deck.systems.apphorialabs.com
# Agent capability. Default 'bypassPermissions' = full host power (the product).
# Set to 'default' to require the SDK's own permission gating instead.
# DECK_PERMISSION_MODE=bypassPermissions
# Auth cookie Secure flag. Defaults to true. Set false ONLY behind a plain-HTTP
# proxy that breaks the localhost secure-context exemption.
# DECK_COOKIE_SECURE=true
# Per-turn agent turn ceiling (denial-of-wallet guard). Unset = no cap for
# interactive sessions; unattended task/cron runs default to 40. Override both:
# DECK_MAX_TURNS=40
# Cheaper model/effort for unattended task + cron runs (interactive chat still uses
# DECK_MODEL). Falls back to DECK_MODEL / SDK default when unset.
# DECK_TASK_MODEL=claude-sonnet-4-5
# DECK_TASK_EFFORT=low
# Minimum seconds between cron fires; a tighter schedule is rejected at create time.
# DECK_CRON_MIN_INTERVAL_SEC=60
# Auth session lifetime in days (sliding renewal). Default 7.
# DECK_SESSION_TTL_DAYS=7
